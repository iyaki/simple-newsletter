{
    "name": "iyaki/simple-newsletter",
    "type": "project",
    "autoload": {
        "psr-4": {
            "SimpleNewsletter\\": "libs/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [{
        "name": "iyaki",
        "email": "me@iyaki.ar"
    }],
    "require": {
        "php": "^8.3",
        "laminas/laminas-feed": "^2.22",
        "laminas/laminas-http": "^2.19",
        "phpmailer/phpmailer": "^7.0",
        "sentry/sentry": "^4.7"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-mutate": "^3.0",
        "phpstan/phpstan": "^2.0",
        "carthage-software/mago": "^1.30.0",
        "dg/bypass-finals": "^1.10",
        "mockery/mockery": "^1.6",
        "symfony/http-client": "^7.0",
        "cebe/php-openapi": "^1.8",
        "rector/rector": "^2.4",
        "phpstan/phpstan-mockery": "^2.0",
        "symfony/options-resolver": "^7.0",
        "symfony/html-sanitizer": "^7.0"
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "XDEBUG_MODE=coverage vendor/bin/pest --coverage --min=75 --testsuite=default --do-not-fail-on-risky",
        "test:e2e": "vendor/bin/pest --testsuite e2e",
        "test:mutation": "vendor/bin/pest --mutate --min=90",
        "lint": "vendor/bin/mago lint",
        "analyze": "vendor/bin/mago analyze",
        "check": ["@lint", "@analyze", "@test:coverage"]
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "platform": {
            "php": "8.3.31"
        }
    }
}
